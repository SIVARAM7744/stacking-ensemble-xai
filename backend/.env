DB_BACKEND=sqlite
SQLITE_PATH=./backend/disaster_prediction.db

# Switch to mysql when ready:
# DB_BACKEND=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your_password
# DB_NAME=disaster_prediction_db

# Optional full override:
# DATABASE_URL=mysql+pymysql://root:your_password@localhost:3306/disaster_prediction_db?charset=utf8mb4

# Optional model overrides:
# FLOOD_MODELS_DIR=../ml_pipeline/models_tuned_v4_flood
# EARTHQUAKE_MODELS_DIR=../ml_pipeline/models_tuned_v3_earthquake
